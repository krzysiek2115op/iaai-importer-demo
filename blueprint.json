{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Kredyt Kompas — demo z wtyczka IAAI Importer",
		"description": "Strona Kredyt Kompas (Start, Kredyty, Kalkulator, O nas, FAQ, Kontakt) z wtyczka IAAI Importer i podstrona 'Nasze auta' w gornym menu — oferta pojazdow (filtry, karty, paginacja)."
	},
	"landingPage": "/",
	"preferredVersions": { "php": "8.2", "wp": "latest" },
	"login": true,
	"steps": [
		{
			"step": "installTheme",
			"themeData": { "resource": "wordpress.org/themes", "slug": "twentytwentyfive" },
			"options": { "activate": true }
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/krzysiek2115op/iaai-importer-demo/main/iaai-importer.zip"
			},
			"options": { "activate": true }
		},
		{
			"step": "writeFile",
			"path": "/wordpress/wp-content/kredyt-kompas-content.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/krzysiek2115op/iaai-importer-demo/main/kredyt-kompas-content.php"
			}
		},
		{ "step": "mkdir", "path": "/wordpress/wp-content/mu-plugins" },
		{
			"step": "writeFile",
			"path": "/wordpress/wp-content/mu-plugins/iaai-demo-seed.php",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/krzysiek2115op/iaai-importer-demo/main/iaai-demo-seed.php"
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Kredyt Kompas",
				"blogdescription": "Kredyty, finanse i auta z aukcji"
			}
		}
	]
}
